<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.bai07.Controller" stylesheets="@style.css" styleClass="root-pane">
    <VBox alignment="CENTER" maxWidth="400.0" maxHeight="500.0" styleClass="glass-container">

        <Text text="UetDoran" styleClass="app-title"/>
        <Label text="ĐĂNG KÝ THÔNG TIN" style="-fx-text-fill: #aaa; -fx-font-size: 16px; -fx-padding: -15 0 10 0;"/>

        <GridPane hgap="15" vgap="15" alignment="CENTER">
            <Label text="Họ tên:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <TextField fx:id="nameField" promptText="Nhập họ tên đầy đủ" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        </GridPane>

        <CheckBox fx:id="statusCheck" text="Đồng ý với các điều khoản dịch vụ." styleClass="check-box"/>

        <HBox alignment="CENTER" spacing="10">
            <Button text="Lưu dữ liệu" onAction="#onSaveButtonClick" styleClass="btn-primary"/>
        </HBox>
    </VBox>
</StackPane>